LLM_PROVIDER=openai
LLM_MODEL=gpt-5
LLM_TEMPERATURE=0.2
LLM_ENABLE_THINKING=
REQUIREMENT_LLM_MODEL=
FEASIBILITY_LLM_MODEL=
ARCHITECT_LLM_MODEL=
PLANNER_LLM_MODEL=
PROMPT_BUILDER_LLM_MODEL=
REVIEWER_LLM_MODEL=

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5
OPENAI_TEMPERATURE=0.2
OPENAI_BASE_URL=

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

OLLAMA_BASE_URL=http://127.0.0.1:11434

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

CHECKPOINTER_BACKEND=memory
CHECKPOINTER_SQLITE_PATH=.data/checkpoints.sqlite
CHECKPOINTER_POSTGRES_DSN=postgresql://postgres:postgres@127.0.0.1:5432/postgres?sslmode=disable
CHECKPOINTER_POSTGRES_PIPELINE=false
CHECKPOINTER_POSTGRES_AUTO_SETUP=true

RATE_LIMIT_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0
RATE_LIMIT_PREFIX=rl
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_RUNS_PER_WINDOW=60

HUMAN_GATE_MAX_ROUNDS=3
